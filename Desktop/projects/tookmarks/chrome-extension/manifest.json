{
  "manifest_version": 3,
  "name": "Tookmarks — Twitter Bookmarks Exporter",
  "version": "1.0.0",
  "description": "Export your Twitter/X bookmarks to a JSON file with one click.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
